"VertexLitGeneric"
{
	"$baseTexture" "models\hound\hl2_houndeye\houndside2"
	"$model" 1
	"$selfillum" 1

	// Use separate self-illum mask on Pre DX9 hardware
	">=dx90_20b"
	{
		"$baseTexture" 		"models\hound\hl2_houndeye\houndside2"
		"$selfillummask" 	"models\hound\hl2_houndeye\houndside2_light"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"models\hound\hl2_rhoundeye\houndside2"
	}

	"$bumpmap" "models\hound\hl2_houndeye\houndside2_normal"
	$phong			1
	$phongexponent		10
	$phongboost		10
	$phongfresnelranges	"[0 0.5 1]"
	$halflambert 1

	$rimlight			1
	$rimlightexponent		1
	$rimlightboost		0.5

}
