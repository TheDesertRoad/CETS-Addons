"VertexLitGeneric"
{
	//"$color"				"[1 1 1]"
	"$baseTexture"			"models/hl2_mompod/black"
	"$translucent"			1
	"$surfaceprop" "metal"

	"$nofog" 1
	"$nodecal" "1"
	"$model" 1
	"$envmap" "env_cubemap"
	"$envmaptint" "[ .1 .2 .3]"

	"$selfillum" 1

	// Use separate self-illum mask on Pre DX9 hardware
	">=dx90_20b"
	{
		"$baseTexture" 		"models/hl2_mompod/black"
		"$selfillummask" 	"models/hl2_mompod/black_l"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"models/hl2_mompod/black"
	}
}