"VertexLitGeneric"
{
	"$baseTexture" "models/xenians/hl2_gargantua/garg_body_baby"
	"$bumpmap" "models/xenians/hl2_gargantua/garg_body_normal"

 	"$phong" "1"
	"$phongexponent" "2"
	"$phongboost"	"0.1"
