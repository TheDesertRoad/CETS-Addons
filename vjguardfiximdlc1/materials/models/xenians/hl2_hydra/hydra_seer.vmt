Vertexlitgeneric
{
	$basetexture models/xenians/hl2_hydra/hydra_brain
	$additive 1
	$nocull 1
	
	$detail models\xenians/hl2_hydra\hydra_brain
	$detailblendmode 5
	$detailblendfactor 1.0
	$detailscale 1
	
	Proxies
	{
		//agressive pulse
		Sine
		{
			sineperiod 6
			sinemin 0.5
			sinemax 2.0
			resultVar "$detailblendfactor"
		}
	}
}
