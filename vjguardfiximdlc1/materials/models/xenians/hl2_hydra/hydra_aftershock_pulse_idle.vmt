Aftershock
{
	$normalmap bumpmaps/bump_organic01
	$refractamount 2.1
	$colortint "[0 1.3 1.6]"
	$SilhouetteThickness 1
	$SilhouetteColor "[0 0.3 4]"
	$GroundMin 8
	$GroundMax 0
	$BlurAmount 1

	Proxies
	{
		//passive pulse
		Sine
		{
			sineperiod 5
			sinemin 0.3
			sinemax 2
			resultVar "$SilhouetteColor[1]"
		}		
		Sine
		{
			sineperiod 5
			sinemin 4
			sinemax 8
			resultVar "$SilhouetteColor[2]"
		}
		Sine
		{
			sineperiod 5
			sinemin 0.6
			sinemax 3
			resultVar "$colortint[2]"
		}
	}
}