		//	sinemax 2
		//	resultVar "$SilhouetteColor[1]"
		//}
		//
		//Sine
		//{
		//	sineperiod 5
		//	sinemin 4
		//	sinemax 8
		//	resultVar "$SilhouetteColor[2]"
		//}
		//Sine
		//{
		//	sineperiod 5
		//	sinemin 0.6
		//	sinemax 3
		//	resultVar "$colortint[2]"
		//}

		//agressive pulse
		Sine
		{
			sineperiod 3
			sinemin 2
			sinemax 6
			resultVar "$SilhouetteColor[0]"
		}
		Sine
		{
			sineperiod 0.5
			sinemin 2
			sinemax 3
			resultVar "$SilhouetteColor[1]"
		}
		
		Sine
		{
			sineperiod 0.3
			sinemin 6
			sinemax 14
			resultVar "$SilhouetteColor[2]"
		}
		Sine
		{
			sineperiod 1
			sinemin 0
			sinemax 0.5
			resultVar "$colortint[0]"
		}
		Sine
		{
			sineperiod 1
			sinemin 1.1
			sinemax 1.4
			resultVar "$colortint[1]"
		}
		Sine
		{
			sineperiod 0.5
			sinemin 2
			sinemax 3
			resultVar "$colortint[2]"
		}
		Sine
		{
			sineperiod 5
			sinemin 0
			sinemax 1
			resultVar "$emissiveBlendStrength"
		}
	}
}