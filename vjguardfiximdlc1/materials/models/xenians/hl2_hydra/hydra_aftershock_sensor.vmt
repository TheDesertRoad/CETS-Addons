DI_Refract_DX90
{
	$basetexture models/xenians/hl2_hydra/hydra_brain
	$model 1
	$nocull 1
	$scale "[1 1]"
	$bumpframe 0
	
	$emissiveBlendEnabled 1
	$emissiveBlendTexture 	  detail/organic_detail_01
	$emissiveBlendBaseTexture detail/organic_detail_01
	$emissiveBlendFlowTexture flowmaps/core_flow
	$emissiveBlendTint "[8 10 13]"
	$emissiveBlendStrength 0.003
	$emissiveBlendScrollVector "[-0.02 -0.02]"
	
	$SILHOUETTEENABLED 1
	$normalmap bumpmaps/bump_organic01
	$refractamount 0.1
	$colortint "[0 1.3 1.6]"
	$SilhouetteThickness 1
	$SilhouetteColor "[0 0.3 4]"
	$GroundMin 8
	$GroundMax 0
	$BlurAmount 1

	Proxies
	{
		//agressive pulse
		Sine
		{
			sineperiod 0.8
			sinemin 2
			sinemax 5
			resultVar "$SilhouetteColor[0]"
		}
		Sine
		{
			sineperiod 6.0
			sinemin 5
			sinemax 12
			resultVar "$SilhouetteColor[1]"
		}		
		Sine
		{
			sineperiod 1.2
			sinemin 4
			sinemax 9
			resultVar "$SilhouetteColor[2]"
		}
		Sine
		{
			sineperiod 4
			sinemin 0.3
			sinemax 0.6
			resultVar "$colortint[0]"
		}
		Sine
		{
			sineperiod 4
			sinemin 0.5
			sinemax 1.5
			resultVar "$colortint[1]"
		}
		Sine
		{
			sineperiod 2.0
			sinemin 2
			sinemax 3
			resultVar "$colortint[2]"
		}
	}
}