"vertexlitgeneric"
{
$baseTexture	models/xenians/hl2_controller/hl1con_cloth
$bumpmap		models/xenians/hl2_controller/hl1con_cloth_normal
	"$phong" "1"
	"$phongboost" "2"
	"$phongexponent" "16"
	"$phongexponenttexture" "Models/vortigaunt/vortigaunt_exponent"
	"$phongalbedotint" "1"
	"$phongfresnelranges" "[.08 .08 .08]"
	"$halflambert" "1"
	"$nodecal" "1"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "10"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "3"

	"$Detail" 				  	  "detail/detail_fabric2"
	"$DetailScale" 			  	  "1"
	"$DetailBlendFactor" 	  	  ".7"
	"$DetailBlendMode" 		   	  "0"
}