VertexLitGeneric
{
	$basetexture models/xenians/hl2_hornet/hornet_b
	$bumpmap models/xenians/hl2_hornet/hornet_n
	$phong 1
	$phongfresnelranges "[-1 -2 -3]"
	$phongexponent 2
	$phongboost 1
	$lightwarptexture	models/xenians/hl2_hornet/warp
	"$selfillum" 1

	// Use separate self-illum mask on Pre DX9 hardware
	">=dx90_20b"
	{
		"$baseTexture" 		"models/xenians/hl2_hornet/hornet_b"
		"$selfillummask" 	"models/xenians/hl2_hornet/hornet_light"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"models/xenians/hl2_hornet/hornet_b"
	}
}
}