VertexLitGeneric
{
	$basetexture "models/xenians/archer/archer_gibs"
	$bumpmap "models/xenians/archer/archer_gibs_normal"
	$surfaceprop Alienflesh

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.71 0.71 0.71]"

	$phong 1
	$phongfresnelranges "[0.51 0.76 1]"
	$phongexponent 25
	$phongboost 1.12
	$phongalbedoboost 1.1

	$rimlight 1
	$rimlightexponent 60
	$rimlightboost 0.5

	//$selfillum 1
	$selfillumtint "[0.28 0.58 0.87]"

	%keywords "bshift , rimas"

	$model 1
}