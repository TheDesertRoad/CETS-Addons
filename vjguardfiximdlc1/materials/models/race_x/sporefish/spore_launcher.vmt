"SDK_VertexLitGeneric"
{
	"$basetexture" "models/weapons/v_spore_launcher/spore_launcher"
	"$bumpmap" "models/weapons/v_spore_launcher/spore_launcher_n"

	"$phong" "1"
	"$phongboost" "1"
	"$phongexponenttexture" "Models/vortigaunt/vortigaunt_exponent"
	"$phongfresnelranges" "[.1 .4 1]"
	"$halflambert" "1"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "2"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "1"										// Boost for ambient cube component of rim lighting
}
