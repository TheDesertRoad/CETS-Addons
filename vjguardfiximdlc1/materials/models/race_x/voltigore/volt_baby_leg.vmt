"SDK_Vertexlitgeneric"
{
	"$basetexture" "models/race_x/voltigore_baby/volt_baby_leg_rework2"
	"$bumpmap" "models/race_x/voltigore_baby/volt_baby_leg_n2"

	"$phong" "1"
	"$phongboost" "0.3"
        "$phongexponent" "24"
	"$phongalbedotint" "1"
	"$phongfresnelranges" "[2 1 1]"
	"$nodecal" "1"
	"$nocull" "1"	
	"$halflambert" "1"

// Rim lighting parameters
	"$rimlight" "1"				// To enable rim lighting (requires phong)
	"$rimlightexponent" "20"             // Exponent for phong component of rim lighting
	"$rimlightboost" "3"	               // Boost for ambient cube component of rim lighting

	$detail "detail\organic_detail_03"
	$detailscale "2"
	$detailblendfactor "1.2"
	$detailblendmode "0"
}
