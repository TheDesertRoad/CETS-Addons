"VertexLitGeneric"
{
	"$baseTexture" "Models/spitter_ant/Antlionhigh_sheet2"
	"$bumpmap" "Models/spitter_ant/Antlionhigh_normal"
	"$surfaceprop"	"Antlion"

	"$model" "1"
	"$phong"     "1"
	"$phongexponent"   "40"
	"$phongboost"   "3"
	"$phongfresnelranges"	"[.1 .3 .5]"

	"$rimlight" "1"
	"$rimlightexponent" "15"
	"$rimlightboost" "1"
	
	"$envmap" "env_cubemap"
	"$envmaptint" "[.03 .08 .09]"
	"$envmapfresnel" "1"

	"$nodecal" "0"
	"$selfillum" 1

	// Use separate self-illum mask on Pre DX9 hardware
	">=dx90_20b"
	{
		"$baseTexture" 		"Models/spitter_ant/Antlionhigh_sheet2"
		"$selfillummask" 	"Models/spitter_ant/Antlionhigh_sheet_l"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"Models/spitter_ant/Antlionhigh_sheet2"
	}
}
