"UnlitTwoTexture"
{
	"$baseTexture" "southernmost/TV_blade"
	"$texture2" "Effects/FilmScan256"
	"$surfaceprop" "glass"
	"$envmap" "env_cubemap"
	"$envmaptint" .3 .3 .3

    "$jumpchance" 0.0
    "$jumpchancethreshold" 0.95
    "$nojump" 0.0
    "$jumpdistance" 0.0
    "$translate1" "[0.0 0.0]"
    "$translate2" "[0.0 0.0]"
    "$scale2" "[3 3]"


"Proxies" 
{ 
        "GaussianNoise"
        {
            "mean" 0.5
            "halfWidth" 0.2
            "minVal" 0.0
            "maxVal" 1.0
            "resultVar" "$jumpchance"            
        }
        "GaussianNoise"
        {
            "mean" 0
            "halfWidth" 0.05
            "minVal" -0.1
            "maxVal" 0.1
            "resultVar" "$jumpdistance"            
        }
        "LessOrEqual"
        {
            "srcVar1" "$jumpchance"
            "srcVar2" "$jumpchancethreshold"
            "lessEqualVar" "$nojump"
            "greaterVar" "$jumpdistance"
            "resultVar" "$translate1[1]"
        }
        "TextureTransform"
        {
            "translateVar" "$translate1"
            "resultVar" "$basetexturetransform"
        }

        "UniformNoise"
        {
            "minVal" 0.0
            "maxVal" 1.0
            "resultVar" "$translate2[0]"            
        }
        "UniformNoise"
        {
            "minVal" 0.0
            "maxVal" 1.0
            "resultVar" "$translate2[1]"            
        }
        "TextureTransform"
        {
            "translateVar" "$translate2"
            "scaleVar" "$scale2"
            "resultVar" "$texture2transform"
        }
        "AnimatedTexture" 
        { 
        "animatedTextureVar" "$basetexture" 
        "animatedTextureFrameNumVar" "$frame" 
        "animatedTextureFrameRate" "0.3" 
         }
    }	
}



 
