// envmaptint_fix
"LightmappedGeneric"
{
	"$envmap" "env_cubemap"
	"$envmaptint" "[ .5 .4 .1 ]"
	"$envmapcontrast" "1"

	"$surfaceprop" "water"
	"%keywords" "Xen"
	"%compileWater" 1

	"$bottommaterial" "xeno/!fluid4"
	"$abovewater" "1"

	"$fogenable" 1
	"$fogcolor" "{255 255 200}"
	"$fogstart" 0.1
	"$fogend" 0.1

	"$basetexture" "xeno/!fluid4"
	"$bumpmap" "xeno/!fluid4_n"
	"$frame" "100"
	"$normalmapalphaenvmapmask" "1"

	"Proxies"
	{

		"AnimatedTexture"
		{
			"animatedtexturevar" "$basetexture"
			"animatedtextureframenumvar" "$frame"
			"animatedtextureframerate" 30.00
		}
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" 0.01
			"texturescrollangle" 0
		}
	}
}