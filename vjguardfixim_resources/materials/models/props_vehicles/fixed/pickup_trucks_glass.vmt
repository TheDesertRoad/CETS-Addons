VertexLitGeneric
{
$baseTexture "models\props_vehicles\fixed/pickup_trucks_glass"
$bumpmap "effects\flat_normal"
$translucent 1
$envmap env_cubemap
$envmaptint "[.8 .8 .8]"
$basemapalphaenvmapmask 1
$envmapfresnel 1
$invertphongmask 1
$halflambert 1
$phong 0
$phongexponent 500
$phongboost 1
$phongfresnelranges "[.3 .6 4]"
$allowdiffusemodulation 0
}
