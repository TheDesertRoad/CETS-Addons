"VertexLitGeneric"
{
	"$basetexture"	"Models/props_qz/tank_liquid"
	"$selfillum" "1"
	"$selfillumtint" "[0.8 0.7 0.1]"
	"$surfaceprop" "slime"
	"%compileSlime" "1"

	"Proxies"
	{

          		  "TextureTransform"
          		  {
           		     "translateVar" "$translate"
            		     "rotateVar" "$angle"
           		     "centerVar" "$center"
               		     "resultVar" "$basetexturetransform"
         		   }
	}
}