"VertexLitGeneric"
{
	"$basetexture" "models\props_natural\xenp"
	"$bumpmap" "models\props_natural\xenp_n"
	"$model" 1
	$halflambert 1

	"$phong" "1"
	"$phongexponent" "128"
	"$phongboost"	"0.5"
	"$phongfresnelranges"	"[1 1 1]"
	"$normalmapalphaenvmapmask" 1

	"$rimlight" "1" 
	"$rimlightexponent" "5" 
	"$rimlightboost" "2.0"

	"Proxies"
	{
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .01
			"texturescrollangle" 16
		}
	}
}
}



