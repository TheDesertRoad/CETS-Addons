"VertexLitGeneric"
{
	$basetexture	"models\props_xen\crystal1"
	$bumpmap 	"models\props_xen\crystal_purestsample_nm"

	$selfillum 1
	$model 		1

	"$envmap" 	"env_cubemap" 
   	"$envmaptint" 	"[.2 .2 .2]"
	"$normalmapalphaenvmapmask" "1"

 	"$emissiveBlendEnabled" 	"1"
	"$emissiveBlendTint" 	"{255 255 255}"
 	"$emissiveBlendTexture" 	"models\props_xen\glow_red3"
	"$emissiveBlendBaseTexture" "models\props_xen\crystal_purestsample_exp"
	"$emissiveBlendFlowTexture" "models\props_xen\glow_red3" //Can use a flow mask that scrolls to create disruptive patterns. Use white for just basic glow.
    	"$emissiveBlendStrength" 	1 //Strength of glow. Can be controlled via proxy for variable glow.
    	"$emissiveBlendScrollVector" "[0.02 0.04]" 
	"$sheenpassenabled" 	"1"
	
	"$lightwarptexture" "models\effects\lightwarp_atlas"

	"$WARPINDEX_DIFF" "1"
	"$WARPINDEX_SPEC" "1"

	$phong 	1
        $phongexponent 	50
       	$phongboost 	5
       	$phongtint 	"[255 255 255]"
       	$halflambert 	1
	$phongfresnelranges "[0 0 0]"  //The angle of the dangle

	$rimlight 		"1"
	$rimlightexponent 	"25" //Range
	$rimlightboost 	"0.015"
}