"VertexLitGeneric"
{
	"$baseTexture" "models/xen_props/xen_pads/pustule_d_tentacles"
	"$bumpmap" "models/xen_props/xen_pads/pustule_n_tentacles"
	"$model" 1
	"$surfaceprop" "alienflesh"

	"$envmapcontrast" "1"
	"$envmapsaturation" 1
	"$envmap"	"env_cubemap"
	"$envmaptint" "[.1 .1 .1]"
	"$normalmapalphaenvmapmask" "1"

	"$phong" "1"
	"$phongboost" "2"
	"$phongexponent" "12"
	"$phongfresnelranges" "[0.05 0.5 1]"
	"$halflambert" "1"

	"$rimlight" "1"				// To enable rim lighting (requires phong)
	"$rimlightexponent" "2"             // Exponent for phong component of rim lighting
	"$rimlightboost" ".5"	               // Boost for ambient cube component of rim lighting
}