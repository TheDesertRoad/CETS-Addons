// So the plan is we'll have this composite texture for various static organic shapes 
// (the tubulars, some small fungi, whatever is too insignificant to require a whole separate sheet.
// So far it's just the tubulars, though. And their UV is just simple cylindric unwrap.
// Once I've made more of these miscellaneous static organic shapes, 
// then it'll be time to bother with this texture. 

VertexLitGeneric
{
	$basetexture models\props_foliage_new/static_organics_composite_dead
	$bumpmap bumpmaps/bump_organic01
	$phongexponenttexture custom_uni/exponent_albedotint
	$halflambert 1

	"$phong" "1"
	"$phongboost" "0.4"
        "$phongexponent" "64"

	"$phongfresnelranges" "[.01 .1 .01]"
	"$phongalbedotint" "1"

	$detail "detail/organic_detail_03"
	$detailscale "16"
	$detailblendfactor "1"
	$detailblendmode "0"
//	$lightwarptexture	models\props_foliage_new/blue_warp
}