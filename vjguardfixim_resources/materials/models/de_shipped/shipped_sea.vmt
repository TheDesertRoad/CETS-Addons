"VertexlitGeneric"
{
	"$basetexture" "models/de_shipped/shipped_sea"
	"$bumpmap" "models/de_shipped/shipped_sea_normal"

	"$normalmapalphaenvmapmask" "1"
	
	"$nocull" "1"

	"$envmap" "env_cubemap"
	"$envmaptint" "[2 2 2]"
	"$envmapcontrast" "1"

$vertexfog 1
$treeSway "1"
$treeSwayHeight "5"
$treeSwayStartHeight "-50"
$treeSwayRadius "100"
$treeSwayStartRadius "0"
$treeSwaySpeed "0"
$treeSwayStrength ".8"
$treeSwayFalloffExp "1"
$treeSwayScrumbleSpeed ".7"
$treeSwayScrumbleStrength "3"
$treeSwayScrumbleFrequency "7"
$treeSwayScrumbleFalloffExp "5000"
$treeSwaySpeedHighWindMultipler "1"
$treeSwaySpeedLerpStart "500"
$treeSwaySpeedLerpEnd "600" 

"Proxies"
	{
	
		"TextureScroll"
		{
			"texturescrollvar"
 			 "$basetexturetransform" //tells the proxy what texture to move. 
			"texturescrollrate" .15 // This is how fast to scroll the texture.
			"texturescrollangle" 270 //this is the angle at which it will scroll. 
		}

		"TextureScroll"		
		{
			"texturescrollvar"
 			 "$bumptransform" //tells the proxy what texture to move.
			"texturescrollrate" .12 // This is how fast to scroll the texture.
			"texturescrollangle" 260 //this is the angle at which it will scroll. 

		}	

 	}
	

}
