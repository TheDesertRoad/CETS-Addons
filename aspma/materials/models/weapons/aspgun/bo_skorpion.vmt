"VertexlitGeneric"
{
                 // Original shader: VertexLitTexture
	"$basetexture" "models\weapons\aspgun\skorpion_d"
	"$bumpmap" "models\weapons\aspgun\skorpion_n"
	"$halflambert" "1"				
	"$nocull" 1		
		
	"$normalmapalphaenvmapmask" 1	
	"$envmap" "env_cubemap"					
	"$envmaptint" "[ .01 .01 .01 ]"					
	"$envmapFresnel" "0.2"	
					
	$phong 1
	$phongexponent 50
	$phongfresnelranges "[5 1 2]"
	$phongboost ".6"
	$basemapalphaphongmask 1
	$nodecal 1
}