"VertexlitGeneric"
{
                 // Original shader: VertexLitTexture
	"$basetexture" "models\weapons\aspgun\skorpion_d_r"
	"$bumpmap" "models\weapons\aspgun\skorpion_n"
	"$halflambert" "1"				
	"$nocull" 1		
		
	"$normalmapalphaenvmapmask" 1	
	"$envmap" "env_cubemap"					
	"$envmaptint" "[ .01 .01 .00 ]"					
	"$envmapFresnel" "0.1"	
					
	$phong 1
	$phongexponent 50
	$phongfresnelranges "[2 3 1]"
	$phongboost ".1"
	$basemapalphaphongmask 1
	$nodecal 1
}