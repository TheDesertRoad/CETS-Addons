VertexLitGeneric
{
$baseTexture "models\cg\aspma\stealth\aspmaeye"
$surfaceprop metal
$selfillum 1
$nodecal 1
	//proxy vars
	$rand 0.0
	$one 1
	$zero 0
	$detailframe 0
	$sineValue 0.0
	$noiseValue 0.0
	$ragdollBoolean 0
	$result 0
	"Proxies"
	{
		"EntityRandom"
           		 {
               			 "scale" "3.00"
              	 		 "resultVar" "$rand"
              	 	 }

		"Sine"
		{
			sineperiod 3.0
			sinemin -0.4
			sinemax 0.7
			timeoffset $rand
			resultVar $sineValue
		}

		"UniformNoise"
		{
			minVal 0.0
			maxVal 1.0
			resultVar $noiseValue
		}

		"LessOrEqual"
		{
			lessEqualVar $one
			greaterVar $zero
			srcVar1 $sineValue
			srcVar2 $noiseValue
			resultVar $selfillumtint
		}

	}
}
