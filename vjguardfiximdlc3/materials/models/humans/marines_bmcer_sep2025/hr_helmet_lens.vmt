VertexLitGeneric
{
	$basetexture "models/humans/marines_bmcer_sep2025/hr_helmet"
	$bumpmap "models/humans/marines_bmcer_sep2025/hr_gasmask_normal"
	$surfaceprop Plastic
	
	//$phong 1 
	$phongfresnelranges "[0.5 0.75 1]"
	$phongexponent 30
	$phongboost 1.005

    
    // GLASS COLOR
	
	$detail "models/humans/marines_bmcer_sep2025/glass_mask" 
	$detailblendmode 1
	$detailscale 1
	$detailblendfactor 0.1   // if you want to make the color less or more contrasting

	$alpha 0.6
	$translucent 1
	$nocull 1
	
	// GLASS.REF

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.55 0.75 0.55]"      // reflection color

	$allowalphatocoverage 1
}