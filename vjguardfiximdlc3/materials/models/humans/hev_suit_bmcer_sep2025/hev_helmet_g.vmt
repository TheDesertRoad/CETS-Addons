	"$baseTexture" "models\humans\hev_suit_bmcer_sep2025\hev_helmet_d"
	"$bumpmap" "models\humans\hev_suit_bmcer_sep2025\hev_helmet_n"

	"$surfaceprop" "metal"

	"$envmap" "env_cubemap"
	"$normalmapalphaenvmapmask" "1"

	"$envmaptint" "[16.01 8.60 1.76]"
//	"$envmaptint" "[8.01 4.60 .88]"
//	"$envmaptint" "[2.01 1.60 .22]"
//	"$envmaptint" "[4.01 2.60 .88]"
//	"$envmaptint" "[0.50 0.50 0.50]"
//	"$envmaptint" "[0.15 0.15 0.15]"
	"$envmapsaturation" "0.5"
	"$envmapcontrast" "1"

	"$phong" "1"
	"$phongboost" "200" //0.5
	"$phongexponent" "15" //25
	"$phongalbedotint" "1"
	"$phongexponenttexture" "models\ninja_bmcer_sep2025/L4D2/exp_tie"
	"$phongfresnelranges"	"[0.4 0.9 2.8]"

	// Rim lighting parameters
	//"$rimlight" "1"
	"$rimlightexponent" "25"
	"$rimlightboost" "0.05"
	
        $detail detail\bm_metal_detail_01 // e.g. for brickwork, concrete...
        $detailscale 5
        $detailblendfactor .5
        $detailblendmode 0
}