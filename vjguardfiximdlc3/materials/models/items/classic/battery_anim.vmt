"VertexLitGeneric"
{
	"$basetexture" "Models/Items/classic/battery"
	"$envmap" "env_cubemap"
	//"$translucent" "1"
	"$nocull" "1"
	"$envmaptint" "[.4 .4 .4]"
	//"$envmapsaturation" .5
	"$normalmapalphaenvmapmask" "1"
	"$EmissiveBlendEnabled" 		"1"
