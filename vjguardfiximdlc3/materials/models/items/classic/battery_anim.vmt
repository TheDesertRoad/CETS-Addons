	"$EmissiveBlendTexture"		"Models/Items/classic/electricity"			// This will be useless, but is required.
	"$EmissiveBlendBaseTexture"  "Models/Items/classic/battery_glow"
	"$EmissiveBlendFlowTexture" 	"Models/Items/classic/battery_flow"	 
	"$EmissiveBlendScrollVector" 	" [ .3 .1 ] " 	
}
