"VertexLitGeneric"
{
	"$bumpmap" "models/ej_sniper/m17_normal"
	"$surfaceprop" "flesh"
	"$selfillum" 1
	"$model" 1
	"$phong" 1
	"$phongboost" "2"
	"$halflambert" "1"
	"$phongexponenttexture" "models/ej_sniper/m17_soldier"
	"$phongalbedotint" "1"										
	"$phongfresnelranges"	"[.1 .5 1.0]"

	// Use separate self-illum mask on Pre DX9 hardware
	">=dx90_20b"
	{
		"$baseTexture" 		"Models/ej_sniper/m17_soldier"
		"$selfillummask" 	"Models/ej_sniper/m17_light"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"Models/ej_sniper/m17_soldier"
	}
}





