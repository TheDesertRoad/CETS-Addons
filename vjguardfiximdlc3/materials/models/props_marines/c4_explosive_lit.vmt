"VertexLitGeneric"
{
	"$basetexture" 	"models/props_marines/c4_d_on"
	"$bumpmap" "models/props_marines/c4_n"
	$selfillum 1
	"$phong" "1"
	"$phongexponent" "32"
	"$phongboost" "1"
	"$phongfresnelranges"	"[0.1 0.6 1]"
	//"$phongalbedotint" "1"
	$phongtint "[ .65 .8 .65 ]"
	"$rimlight" "1"				// To enable rim lighting (requires phong)
	"$rimlightexponent" "32"		// Exponent for phong component of rim lighting
	"$rimlightboost" ".25"			// Boost for ambient cube component 
"$model" 1
}