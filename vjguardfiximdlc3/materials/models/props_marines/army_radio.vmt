"VertexLitGeneric"
{
	"$baseTexture"		"models/props_marines/army_radio_d"
	"$bumpmap"			"models/props_marines/army_radio_n"

	"$model" "1"

	"$envmap"			"env_cubemap"
    "$envmaptint"		"[.3 .3 .3]"

	// DEV NOTE: 
	// as long as $phong is set to 1,
	//
	// setting $basealphaenvmapmask to 0 
	//
	// will allow you to utilize an alpha channel in the diffuse
	// to handle the envmap reflections
	//
	// while the alpha channel for the normal map can separately handle the phong lighting
	
	"$basealphaenvmapmask"	"0"
	
	"%keywords" "bms, Andrea, ks"
	
	"$phong" "1"
	"$phongboost"	"1"
	"$phongexponent" "30"
	 $phongfresnelranges "[0.05 0.5 1]"


// Rim lighting parameters

	"$rimlight" "1"				// To enable rim lighting (requires phong)
	"$rimlightexponent" "45"		// Exponent for phong component of rim lighting
	"$rimlightboost" ".1"			// Boost for ambient cube component 
 	
}
