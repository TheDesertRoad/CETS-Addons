"VertexLitGeneric"
{
	"$basetexture" "models/synth/assault"
	"$bumpmap" "models/synth/assault_normal"
	"$envmapmask" "models/Synth/assault_mask"
	"$envmap" "env_cubemap"
	"$multipass" 1

	"$envmaptint" "[ .01 .01 .01 ]"
	"$normalmapalphaenvmapmask" 1
	"$halflambert" 1
	// -- From here down is new stuff which will only be applied if $phong is set to 1 --
 
 	"$phong"     "1"
 	"$phongboost"   "2"

	"$phongexponent"   "25"
 	"$phongwarptexture" "Models/synth/synthenvmap"
 	"$phongalbedotint" 1

	$detail "detail\noise_detail_01"
	$detailscale "7.74"
	$detailblendfactor "0.4"
	$detailblendmode "0"
}