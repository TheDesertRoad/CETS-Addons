"VertexLitGeneric"
{
	// Original shader: VertexLitTexture
	"$basetexture" "models/Weapons/w_hopwire/ball_sphere"
	"$bumpmap" "models/Weapons/w_hopwire/ball_sphere_n"
	"$halflambert" 1
	"$selfillum" 	1

	">=dx90_20b"
	{
		"$baseTexture" 		"models/Weapons/w_hopwire/ball_sphere"
		"$selfillummask" 	"models/Weapons/w_hopwire/ball_sphere_l"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"models/Weapons/w_hopwire/ball_sphere"
	}

	"360?$color2" "[ 0.8 0.8 0.8 ]"

	"$phong" "1"
	"$phongexponent" "12"
	"$phongboost"	"16"
	"$phongfresnelranges"	"[.1 0.8 3]"

	"$envmaptint" "[.1 .12 .1]"
	"$envmap" "env_cubemap"
}
