VertexLitGeneric
{
	$basetexture "models/hl2_cremator/immolator_uvw"
	$bumpmap "models/hl2_cremator/immolator_N"
	"$selfillum" 1
	"$model" 1
	"$phong" 1
	"$phongboost" "2"
	"$halflambert" "1"
	"$phongalbedotint" "1"										
	"$phongfresnelranges"	"[.1 .5 1.0]"

	// Use separate self-illum mask on Pre DX9 hardware
	">=dx90_20b"
	{
		"$baseTexture" 		"models/hl2_cremator/immolator_uvw"
		"$selfillummask" 	"models/hl2_cremator/immolator_uvw_l"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<dx90_20b"
	{
		"$baseTexture" 	"models/hl2_cremator/immolator_uvw"
	}
}